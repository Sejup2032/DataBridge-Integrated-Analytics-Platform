{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "adf-sp-project-seju"
		},
		"Azuredatalakestorage_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'Azuredatalakestorage'"
		},
		"azuresqldb_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'azuresqldb'"
		},
		"Azuredatalakestorage_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://spoazuredatalakestorage.dfs.core.windows.net/"
		},
		"azuresqldb_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "spoazureprojectserver.database.windows.net"
		},
		"azuresqldb_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "sejuspoazureprojectdb"
		},
		"azuresqldb_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "sejal"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "adf-sp-project-seju_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"Azuredatalakestorage_accountKey": {
						"value": "[parameters('Azuredatalakestorage_accountKey')]"
					},
					"azuresqldb_password": {
						"value": "[parameters('azuresqldb_password')]"
					},
					"Azuredatalakestorage_properties_typeProperties_url": {
						"value": "[parameters('Azuredatalakestorage_properties_typeProperties_url')]"
					},
					"azuresqldb_properties_typeProperties_server": {
						"value": "[parameters('azuresqldb_properties_typeProperties_server')]"
					},
					"azuresqldb_properties_typeProperties_database": {
						"value": "[parameters('azuresqldb_properties_typeProperties_database')]"
					},
					"azuresqldb_properties_typeProperties_userName": {
						"value": "[parameters('azuresqldb_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}